{
  "name": "artea-blog",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:bg": "astro dev --background",
    "dev:stop": "astro dev stop",
    "dev:status": "astro dev status",
    "dev:logs": "astro dev logs",
    "build": "astro build",
    "preview": "astro build && astro preview",
    "astro": "astro",
    "fmt": "vp fmt --write .",
    "fmt:check": "vp fmt --check .",
    "lint": "vp lint . --type-aware --tsconfig ./tsconfig.json",
    "lint:fix": "vp lint . --type-aware --tsconfig ./tsconfig.json --fix"
  },
  "dependencies": {
    "@astrojs/markdown-satteri": "^0.3.2",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/react": "^6.0.0",
    "@astrojs/vue": "^7.0.0",
    "@nullpinter/satteri-katex": "^0.1.2",
    "astro": "^7.0.2",
    "d3-geo": "^3.1.1",
    "maplibre-gl": "^5.24.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^8.1.1",
    "satteri": "^0.9.3",
    "sharp": "^0.35.2",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@iconify-json/tabler": "^1.2.35",
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/topojson-client": "^3.1.5",
    "@unocss/astro": "^66.7.2",
    "@unocss/preset-attributify": "^66.7.2",
    "@unocss/preset-wind3": "^66.7.2",
    "@unocss/reset": "^66.7.3",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "simple-git-hooks": "^2.13.1",
    "topojson-client": "^3.1.0",
    "typescript": "^6.0.3",
    "unocss": "^66.7.2",
    "vite-plus": "^0.2.1"
  },
  "simple-git-hooks": {
    "pre-commit": "$HOME/.vite-plus/bin/vp exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": [
      "vp lint --type-aware --tsconfig ./tsconfig.json --fix",
      "vp fmt --write"
    ],
    "*.astro": [
      "vp lint --type-aware --tsconfig ./tsconfig.json --fix"
    ],
    "*.{css,md,mdx,json,jsonc,yaml,yml,toml}": [
      "vp fmt --write"
    ]
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.9.0"
}
