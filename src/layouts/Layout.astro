---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import LivingTree from '../components/LivingTree.astro';
import TravelMap from '../components/travel/TravelMap';
import '../styles/global.css';
import '../styles/markdown.css';

export interface Props {
  title: string;
  description?: string;
  background?: 'tree' | 'map' | 'none';
}

const {
  title,
  description = 'Artea\'s blog',
  background = 'tree',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/avatar.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="/katex.min.css" />
    <ClientRouter />
  </head>
  <body class="min-h-screen bg-gradient-primary text-gray-900 font-sans antialiased">
    {background === 'tree' && <LivingTree />}
    {
      background === 'map' && (
        <div id="travel-map-bg" aria-hidden="true">
          <div class="travel-map-mask"></div>
          <div class="travel-map-stage">
            <TravelMap client:only="react" />
          </div>
        </div>
      )
    }
    <div class="flex flex-col min-h-screen relative z-10">
      <Header />
      <main class="flex-1 relative">
        <slot />
      </main>
    </div>
  </body>
</html>

<style is:global>
html {
  font-family: var(--a-font-system);
  scroll-behavior: smooth;
}

@supports (scrollbar-gutter: stable) {
  html {
    scrollbar-gutter: stable;
  }
}

code {
  font-family: var(--a-font-mono);
}

::selection {
  background-color: oklch(0.67 0.15 145 / 0.2);
  color: var(--a-color-accent-strong);
}

a {
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

input:focus,
textarea:focus {
  outline: 2px solid oklch(0.67 0.15 145 / 0.5);
  outline-offset: 2px;
}

#travel-map-bg {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  user-select: none;
  overflow: hidden;
}

#travel-map-bg .travel-map-mask {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(
      circle at 50% 30%,
      rgb(255 255 255 / 0.42),
      transparent 42%
    ),
    linear-gradient(
    to bottom,
    rgb(249 250 251 / 0.24),
    rgb(255 255 255 / 0.08) 34%,
    rgb(255 255 255 / 0.28)
  );
}

#travel-map-bg .travel-map-stage {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rem 0 0;
}
</style>
